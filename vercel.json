{
  "buildCommand": "cd shared && npm install && npm run build ; cd ../web-app && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "web-app/dist",
  "installCommand": "echo 'skip root install'",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
