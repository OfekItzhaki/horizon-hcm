# Horizon-HCM Environment Configuration Template
# Copy this file to .env for local development
# For production, use AWS Secrets Manager or GitHub Secrets

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
APP_NAME=Horizon-HCM
APP_URL=http://localhost:3000

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://username:password@localhost:5432/horizon_hcm
# For production, use format: postgresql://user:pass@host:5432/dbname?schema=public&sslmode=require

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Authentication
# ============================================
# Generate keys with: npm run generate:keys
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# ============================================
# Push Notifications
# ============================================
# Firebase Cloud Messaging (FCM)
FCM_PROJECT_ID=your-project-id
FCM_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_FCM_KEY\n-----END PRIVATE KEY-----
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Apple Push Notification Service (APNS)
APNS_KEY_ID=YOUR_KEY_ID
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_APNS_KEY\n-----END PRIVATE KEY-----
APNS_PRODUCTION=false

# Web Push (VAPID)
WEB_PUSH_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
WEB_PUSH_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
WEB_PUSH_SUBJECT=mailto:admin@example.com

# ============================================
# File Storage
# ============================================
# Storage provider: 's3' or 'azure'
STORAGE_PROVIDER=s3

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=horizon-hcm-files

# Azure Blob Storage Configuration (alternative to S3)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=horizon-hcm-files

# File Upload Limits
MAX_FILE_SIZE_IMAGE=10485760
MAX_FILE_SIZE_DOCUMENT=52428800

# ============================================
# Email Service (Optional)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@horizon-hcm.com

# ============================================
# Logging and Monitoring
# ============================================
# Seq Configuration
SEQ_SERVER_URL=http://localhost:5341
SEQ_API_KEY=your-seq-api-key

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# Monitoring Configuration
MONITORING_ENABLED=true
MONITORING_CHECK_INTERVAL=60000
MONITORING_BUFFER_SIZE=100

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Alert Thresholds
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_RESPONSE_TIME_THRESHOLD=5000
ALERT_DB_QUERY_THRESHOLD=50
ALERT_CACHE_HIT_RATE_THRESHOLD=0.3
ALERT_MEMORY_THRESHOLD=0.9

# ============================================
# Application Performance Monitoring (APM)
# ============================================

# Enable/disable Elastic APM
ELASTIC_APM_ACTIVE=false

# APM Service Name (as it appears in APM dashboard)
ELASTIC_APM_SERVICE_NAME=horizon-hcm

# APM Server URL (Elastic APM server endpoint)
ELASTIC_APM_SERVER_URL=http://localhost:8200

# APM Secret Token (for authentication with APM server)
# ELASTIC_APM_SECRET_TOKEN=your-secret-token

# Transaction Sample Rate (1.0 = 100%, 0.1 = 10%)
ELASTIC_APM_SAMPLE_RATE=1.0

# APM Log Level (trace, debug, info, warn, error, fatal)
ELASTIC_APM_LOG_LEVEL=info

# ============================================
# Security
# ============================================
# Application-level encryption key (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=YOUR_32_BYTE_BASE64_ENCODED_KEY

# HMAC secret for request signing (generate with: openssl rand -base64 32)
HMAC_SECRET=YOUR_HMAC_SECRET_KEY

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:19006
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS_AUTHENTICATED=1000
RATE_LIMIT_MAX_REQUESTS_UNAUTHENTICATED=100

# IP Whitelisting (comma-separated, leave empty to disable)
IP_WHITELIST=

# ============================================
# Third-party Services
# ============================================
# Stripe Payment Processing (if applicable)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Malware Scanning
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ============================================
# Feature Flags
# ============================================
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_FILE_UPLOAD=true
FEATURE_WEBHOOKS=true
FEATURE_ANALYTICS=true
FEATURE_REAL_TIME=true

# ============================================
# Internationalization
# ============================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,he
DEFAULT_TIMEZONE=UTC

# ============================================
# Performance
# ============================================
# Cache TTL (in seconds)
CACHE_TTL_DEFAULT=300
CACHE_TTL_USER_PROFILE=600
CACHE_TTL_BUILDING=300

# Database Connection Pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# Development Only
# ============================================
# Enable Swagger documentation
SWAGGER_ENABLED=true

# Enable debug logging
DEBUG=false

# Seed database on startup
AUTO_SEED=false
